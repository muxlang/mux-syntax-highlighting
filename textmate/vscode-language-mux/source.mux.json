{
  "name": "Mux",
  "scopeName": "source.mux",
  "fileTypes": [".mux"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#literals" },
    { "include": "#delimiters" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mux",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mux",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "comment.block.mux",
              "match": "/\\*.*?\\*/"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mux",
          "match": "\\b(if|else|for|while|match|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.mux",
          "match": "\\b(auto|func|returns|return|const|class|interface|enum|import)\\b"
        },
        {
          "name": "keyword.operator.mux",
          "match": "\\b(as|in|is)\\b"
        },
        {
          "name": "constant.language.mux",
          "match": "\\b(none|true|false|common)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.mux",
          "match": "(=|\\+=|-=|\\*=|/=|%=)"
        },
        {
          "name": "keyword.operator.arithmetic.mux",
          "match": "(\\+|\\-|\\*|\\*\\*|/|%|\\+\\+|--)"
        },
        {
          "name": "keyword.operator.comparison.mux",
          "match": "(==|!=|<|<=|>|>=)"
        },
        {
          "name": "keyword.operator.logical.mux",
          "match": "(&&|\\|\\|)"
        },
        {
          "name": "keyword.operator.mux",
          "match": "(!|&|\\.\\.|\\.)"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.numeric.integer.mux",
          "match": "\\b[-+]?[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.float.mux",
          "match": "\\b[-+]?([0-9][0-9_]*\\.([0-9][0-9_]*)?|\\.[0-9][0-9_]*)([eE][-+]?[0-9][0-9_]*)?\\b"
        },
        {
          "name": "string.quoted.single.mux",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.mux",
              "match": "\\\\([nrt0\\\\'\" ])"
            }
          ]
        },
        {
          "name": "string.quoted.double.mux",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mux",
              "match": "\\\\([nrt0\\\\'\" ])"
            }
          ]
        },
        {
          "name": "string.quoted.triple.double.mux",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "constant.character.escape.mux",
              "match": "\\\\([nrt0\\\\'\" ])"
            }
          ]
        },
        {
          "name": "variable.language.mux",
          "match": "\\b_\\b"
        }
      ]
    },
    "delimiters": {
      "patterns": [
        {
          "name": "punctuation.mux",
          "match": "[(){}[\\],:]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.mux",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
